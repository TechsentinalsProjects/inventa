# ─── SMTP Email ───────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your main Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Must match SMTP_USER. Format: Display Name <email@address.com>
SMTP_FROM=Inventa Systems <your-gmail@gmail.com>

# ─── Business Configuration ───────────────────────────────────────────────────
# All contact/quote/enquiry/service/career/callback emails are sent to BUSINESS_EMAIL.
# Also used as the mailto: link shown in every outbound email's footer.
# Note: this is the internal mail recipient, not the email address shown on the
# public site UI (that one — inquiry@inventasystems.in — is hardcoded in the frontend).
BUSINESS_EMAIL=dharapanchal@inventasystems.in

# WhatsApp number (country code + number, digits only, no spaces or +).
# Also used as the tel: link/display number shown in every outbound email's footer.
WHATSAPP_PHONE=919313840714

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed frontend origins
# Production example: https://www.inventasystems.in,https://inventasystems.in
CORS_ORIGIN=http://localhost:5000
