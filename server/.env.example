# ─── SMTP Email ───────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your main Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Must match SMTP_USER. Format: Display Name <email@address.com>
SMTP_FROM=Inventa Systems <your-gmail@gmail.com>

# ─── Business Configuration ───────────────────────────────────────────────────
# All contact/quote/enquiry emails are sent to BUSINESS_EMAIL
BUSINESS_EMAIL=your-business-email@example.com

# Displayed in email footers and contact pages
BUSINESS_PHONE=+91 XXXXX XXXXX
BUSINESS_ADDRESS=Your Lab Address, City, State, PIN

# Logo URL used in HTML email templates (full absolute URL)
BUSINESS_LOGO_URL=https://www.inventasystems.in/image.png

# WhatsApp number (country code + number, digits only, no spaces or +)
WHATSAPP_PHONE=91XXXXXXXXXX

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed frontend origins
# Production example: https://www.inventasystems.in,https://inventasystems.in
CORS_ORIGIN=http://localhost:5000
